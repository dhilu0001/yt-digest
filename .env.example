# Copy this file to .env and fill in your real values.
# .env is git-ignored — never commit it.

YOUTUBE_API_KEY=your-google-cloud-console-api-key-here
CHANNELS=@NateBJones
MAX_VIDEOS_PER_RUN=5

# LLM provider: "gemini" (default), "groq" (free, generous limits), or "openai"
LLM_PROVIDER=groq

# Groq — free API key from console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — from aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI — from platform.openai.com
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# For initial backfill — set BACKFILL=true and run manually
# BACKFILL=true
# BACKFILL_SINCE=2024-01-01T00:00:00Z
